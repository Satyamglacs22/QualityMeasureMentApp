{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=QuantityMeasurementAppDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyForJWTTokenGenerationThatShouldBeAtLeast32CharactersLong!",
    "Issuer": "QuantityMeasurementApp",
    "Audience": "QuantityMeasurementAppUsers",
    "TokenExpiryInMinutes": 15,
    "RefreshTokenExpiryInDays": 7
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
      "RedirectUri": "http://localhost:5000/api/v1/auth/google/callback"
    }
  },
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}